@model IEnumerable<StudentManagementSystem.Models.Student>
@{
    ViewData["Title"] = "Students";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var students = Model.ToList();
}

<div class="page-header">
    <div>
        <h1>Students</h1>
        <p>View all active students in the system</p>
    </div>
</div>

<div class="profile-card">
    <div class="search-box mb-3">
        <input type="text" id="searchInput" placeholder="Search by name or ID..." class="form-control" />
    </div>

    @if (students.Count > 0)
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>National ID</th>
                        <th>Birth Date</th>
                        <th>Grade</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in students)
                    {
                        <tr>
                            <td><strong>@student.Name</strong></td>
                            <td>@student.Email</td>
                            <td>@student.NationalId</td>
                            <td>@student.BirthDate?.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (student.TotalGrade.HasValue)
                                {
                                    <span class="status-badge present">@student.TotalGrade.Value.ToString("F2")</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@student.StudentId" class="icon-btn edit-btn" title="View">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a asp-action="Attendance" asp-route-id="@student.StudentId" class="icon-btn edit-btn" title="Attendance">
                                        <i class="fa-solid fa-calendar-check"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 40px 20px; color: #64748b;">
            <i class="fa-solid fa-inbox" style="font-size: 32px; margin-bottom: 12px; display: block; opacity: 0.5;"></i>
            <p>No students found</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('tbody tr');

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}
