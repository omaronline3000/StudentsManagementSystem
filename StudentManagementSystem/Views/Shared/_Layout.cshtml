@using Microsoft.AspNetCore.Http
@{
    var userType = Context.Session.GetString("UserType");
    var userName = Context.Session.GetString("UserName") ?? "Guest";
    var isLoggedIn = !string.IsNullOrWhiteSpace(userType);
    var pageTitle = ViewData["Title"] as string ?? "Student Management System";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    Func<string, string, string> IsActive = (controller, action) =>
    {
        if (currentController.Equals(controller, StringComparison.OrdinalIgnoreCase))
        {
            if (string.IsNullOrEmpty(action) || currentAction.Equals(action, StringComparison.OrdinalIgnoreCase))
                return "active";
        }
        return "";
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - StudentManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        @if (isLoggedIn)
        {
            <aside class="app-sidebar">
                <div class="sidebar-header">
                    <h2>Student Management</h2>
                    <p>@userType Portal</p>
                </div>

                @if (userType == "Student")
                {
                    <a asp-controller="Student" asp-action="Profile" class="nav-btn @IsActive("Student", "Profile")">
                        <i class="fa-solid fa-user-graduate"></i>
                        Profile
                    </a>
                    <a asp-controller="Student" asp-action="Attendance" class="nav-btn @IsActive("Student", "Attendance")">
                        <i class="fa-solid fa-calendar-check"></i>
                        Attendance
                    </a>
                }
                else if (userType == "Teacher")
                {
                    <a asp-controller="Teacher" asp-action="Profile" class="nav-btn @IsActive("Teacher", "Profile")">
                        <i class="fa-solid fa-chalkboard-user"></i>
                        Profile
                    </a>
                    <a asp-controller="Attendance" asp-action="Upload" class="nav-btn @IsActive("Attendance", "Upload")">
                        <i class="fa-solid fa-file-arrow-up"></i>
                        Upload Attendance
                    </a>
                    <a asp-controller="Attendance" asp-action="Index" class="nav-btn @IsActive("Attendance", "Index")">
                        <i class="fa-solid fa-calendar-days"></i>
                        Sessions
                    </a>
                }
                else if (userType == "Admin")
                {
                    <a asp-controller="Admin" asp-action="Index" class="nav-btn @IsActive("Admin", "Index")">
                        <i class="fa-solid fa-chart-line"></i>
                        Dashboard
                    </a>
                    <a asp-controller="Admin" asp-action="Students" class="nav-btn @IsActive("Admin", "Students")">
                        <i class="fa-solid fa-graduation-cap"></i>
                        Students
                    </a>
                    <a asp-controller="Admin" asp-action="Teachers" class="nav-btn @IsActive("Admin", "Teachers")">
                        <i class="fa-solid fa-chalkboard-user"></i>
                        Teachers
                    </a>
                }

                <a asp-controller="Account" asp-action="Logout" class="logout-btn">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    Logout
                </a>
            </aside>
        }

        <main class="app-main" style="@(isLoggedIn ? "" : "width: 100%;")">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
