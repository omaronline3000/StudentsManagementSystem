@model StudentManagementSystem.ViewModels.TeacherProfileViewModel
@{
    ViewData["Title"] = "Teacher Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Welcome, @Model.Teacher.Name</h1>
        <p>Manage attendance uploads and view your sessions</p>
    </div>
    <div class="header-actions">
        <a asp-controller="Attendance" asp-action="Upload" class="btn-brand">
            <i class="fa-solid fa-file-arrow-up"></i>
            Upload Attendance
        </a>
    </div>
</div>

<div class="content-grid">
    <section class="profile-card">
        <h2><i class="fa-solid fa-user me-2"></i>My Information</h2>
        <div class="profile-list">
            <div><span>Email</span><strong>@Model.Teacher.Email</strong></div>
            <div><span>Position</span><strong>@Model.Teacher.Position</strong></div>
            <div><span>Address</span><strong>@Model.Teacher.Address</strong></div>
        </div>
    </section>

    <section class="table-card">
        <div class="card-head">
            <h2><i class="fa-solid fa-clock-list me-2"></i>Recent Sessions</h2>
            <a asp-controller="Attendance" asp-action="Index" class="link-action">View all →</a>
        </div>

        @if (Model.RecentSessions.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Date</th>
                            <th>Uploaded File</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model.RecentSessions.OrderByDescending(s => s.CreatedAt))
                        {
                            <tr>
                                <td><strong>@session.CourseTitle</strong></td>
                                <td>@session.AttendanceDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <i class="fa-solid fa-file-excel"></i>
                                    @session.UploadedFileName
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 30px 20px; color: #64748b;">
                <i class="fa-solid fa-inbox" style="font-size: 28px; margin-bottom: 8px; display: block; opacity: 0.5;"></i>
                <p>No attendance sessions yet</p>
            </div>
        }
    </section>
</div>
