@model StudentManagementSystem.Models.Teacher
@{
    ViewData["Title"] = "Add Teacher";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Add New Teacher</h1>
        <p>Register a new teacher in the system</p>
    </div>
    <div class="header-actions">
        <a asp-controller="Admin" asp-action="Teachers" class="btn-outline-brand">
            <i class="fa-solid fa-arrow-left"></i> Back to Teachers
        </a>
    </div>
</div>

<div class="profile-card">
    <form asp-controller="Admin" asp-action="TeacherCreate" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label">Full Name</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="NationalId" class="form-label">National ID</label>
                <input asp-for="NationalId" class="form-control" required />
                <span asp-validation-for="NationalId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Position" class="form-label">Position</label>
                <input asp-for="Position" class="form-control" required />
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="Address" class="form-label">Address</label>
            <input asp-for="Address" class="form-control" required />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-end">
            <button type="submit" class="btn-brand">
                <i class="fa-solid fa-save"></i> Save Teacher
            </button>
        </div>
    </form>
</div>