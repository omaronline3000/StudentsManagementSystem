@model List<Admin>
@{
    ViewData["Title"] = "Admin Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="top-bar">
    <h1>Admin Management</h1>
</div>

<div class="search-box">
    <input type="text" id="searchInput" placeholder="Search by Email..." class="form-control">
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var admin in Model)
                {
                    <tr class="admin-row" data-email="@admin.Email?.ToLower() ?? """>
                        <td>@admin.Email</td>
                        <td>
                            <div class="action-buttons">
                                <a asp-controller="Admin" asp-action="AdminDetails" asp-route-adminId="@admin.AdminId" class="icon-btn edit-btn" title="View">
                                    <i class="fa-regular fa-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2" style="text-align:center; padding:30px; color:#999;">
                        No admins found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput')?.addEventListener('keyup', function () {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('.admin-row');

            rows.forEach(row => {
                const email = row.getAttribute('data-email');

                if (email.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}
