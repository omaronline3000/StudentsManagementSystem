@model StudentManagementSystem.Models.Student
@{
    ViewData["Title"] = "Edit Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Edit Student</h1>
        <p>Update student information</p>
    </div>
    <div class="header-actions">
        <a asp-controller="Admin" asp-action="Students" class="btn-outline-brand">
            <i class="fa-solid fa-arrow-left"></i> Back to Students
        </a>
    </div>
</div>

<div class="profile-card">
    <form asp-controller="Admin" asp-action="StudentEdit" method="post">
        <input type="hidden" asp-for="StudentId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label">Full Name</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="NationalId" class="form-label">National ID</label>
                <input asp-for="NationalId" class="form-control" required />
                <span asp-validation-for="NationalId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="TotalGrade" class="form-label">GPA</label>
                <input asp-for="TotalGrade" type="number" step="0.01" min="0" max="4" class="form-control" required />
                <span asp-validation-for="TotalGrade" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="Address" class="form-label">Address</label>
            <input asp-for="Address" class="form-control" required />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-end mt-4">
            <button type="submit" class="btn-brand">
                <i class="fa-solid fa-save"></i> Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
